# CCP Server Configuration
PORT=8082
HOST=127.0.0.1

# Auth token that Claude Code / Codex must use
# Set ANTHROPIC_AUTH_TOKEN=super in your client env
CCP_AUTH_TOKEN=super

# Master secret for AES-256 encryption of stored API keys (min 32 chars)
CCP_ENCRYPTION_SECRET=change_this_to_a_long_random_secret_value_32chars

# Admin panel allowed origins (comma-separated)
ADMIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info
